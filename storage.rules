rules_version = '2';

// Firebase Storage security rules for dHUB.
// Paste these into the Firebase console (Storage → Rules) AFTER you enable
// Storage. Until then, dHUB stores plasmid maps as compressed images inside
// the Realtime Database (/journal/plasmids), so nothing is blocked.
//
// Only the admin (Jon) can read/write private lab files.

service firebase.storage {
  match /b/{bucket}/o {

    // Private plasmid maps / labbook attachments — admin only.
    match /plasmids/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'maciciorjon@gmail.com';
    }
    match /labbook/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'maciciorjon@gmail.com';
    }

    // Everything else denied by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
